# Configuración por defecto del core. Si vas a deployar **solo el core**
# (sin un customer-layer encima), copia este archivo a `.env` y completa
# los valores. Si vas a deployar combinando un layer (ej. postventa-accesos),
# usá el `.env` del layer en su lugar — este se ignora.
#
# Generar:  openssl rand -base64 32 (postgres) / openssl rand -hex 32 (auth)

# Secretos de infraestructura
# ------------------------------------------------------------
POSTGRES_PASSWORD=cambiar_por_un_password_largo_y_random
AUTH_SECRET=cambiar_por_un_secreto_de_64_caracteres_hexadecimales
AUTH_COOKIE_SECURE=false                                # true cuando haya HTTPS

# Branding por defecto (opcionales — sin esto el core usa textos genéricos)
# ------------------------------------------------------------
# VITE_BRAND_DEFAULT_NAME=Mi Empresa
# VITE_LOCALE=es-PA
# VITE_GEOCODE_COUNTRY_SUFFIX=, Panamá
# VITE_MAP_DEFAULT_CENTER=9.0,-79.5
# BRAND_DEFAULT_NAME=Mi Empresa
