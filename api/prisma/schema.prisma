generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  // Rol del usuario: admin | supervisor | tecnico | lectura.
  // Default 'admin' para que los usuarios existentes antes de esta columna
  // mantengan acceso total tras el `prisma db push` (migración aditiva).
  role         String   @default("admin")
  createdAt    DateTime @default(now())
}

// Secuencias parametrizables (equivalente a ir.sequence de Odoo). Permite
// autogenerar identificadores con prefijo + padding + reset cíclico.
// El siguiente número se incrementa de forma atómica (UPDATE...RETURNING
// dentro de una transacción) para garantizar consecutivos sin huecos.
model Sequence {
  id         Int       @id @default(autoincrement())
  // Identificador estable usado por el código para pedir el siguiente número.
  // Ej.: "orden.numero". Único en todo el sistema.
  code       String    @unique
  // Nombre legible para mostrar en la UI de Ajustes.
  name       String
  // Prefijo con placeholders: {year} (2026), {year2} (26), {month} (05), {day} (17).
  prefix     String    @default("")
  // Sufijo con los mismos placeholders.
  suffix     String    @default("")
  // Cantidad de dígitos del número (rellena con ceros a la izquierda).
  padding    Int       @default(5)
  // Próximo número a entregar.
  nextNumber Int       @default(1)
  // De cuánto en cuánto avanza (normalmente 1).
  increment  Int       @default(1)
  // Reset automático del contador: "never" | "yearly" | "monthly".
  resetCycle String    @default("never")
  // Última vez que se reseteó el contador (se usa para detectar cuándo toca el próximo reset).
  lastReset  DateTime?
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

// Datos generales de la organización. Es un singleton: usamos id=1.
// Si la fila no existe, GET /api/empresa la crea con valores por defecto.
model Empresa {
  id        Int      @id @default(1)
  nombre    String   @default("")
  ruc       String?
  telefono  String?
  email     String?
  direccion String?
  // Path relativo dentro del volumen /app/uploads (ej. "logo-1715890000.png").
  // El frontend lo sirve como /uploads/<logoFile>. Null = usar fallback.
  logoFile  String?
  updatedAt DateTime @updatedAt
}

model Tecnico {
  id       Int     @id @default(autoincrement())
  nombre   String
  telefono String?
  email    String?
  activo   Boolean @default(true)
  ordenes  Orden[]
}

model Cliente {
  id             Int     @id @default(autoincrement())
  nombre         String
  contacto       String?
  telefono       String?
  email          String?
  direccion      String?
  lat            Float?
  lng            Float?
  contratoActivo Boolean @default(true)
  notas          String?
  ordenes        Orden[]
}

model Tipo {
  id      Int     @id @default(autoincrement())
  nombre  String
  color   String
  activo  Boolean @default(true)
  ordenes Orden[]
}

model Estado {
  id      Int     @id @default(autoincrement())
  nombre  String
  color   String
  orden   Int     @default(1)
  esFinal Boolean @default(false)
  activo  Boolean @default(true)
  ordenes Orden[]
}

model Prioridad {
  id      Int     @id @default(autoincrement())
  nombre  String
  color   String
  nivel   Int     @default(1)
  ordenes Orden[]
}

model Orden {
  id               Int      @id @default(autoincrement())
  // Identificador legible de la orden. A partir de la sequence `orden.numero`
  // se autogenera al crear (ej.: "OS-2026-00042") cuando no se provee uno;
  // si el usuario lo escribe manualmente, se respeta el valor dado. No es
  // único en BD: una misma orden lógica puede partirse en varias visitas.
  numero           String?
  // Identificador en un sistema externo (SAP, NetSuite, etc.). Editable
  // libremente, no se autogenera. Antes de 2026-05-17 esta información
  // vivía en el campo `numero` — migración aditiva movió los valores acá.
  referenciaExterna String?
  fechaProgramada  String
  horaInicio       String
  duracionEstimada Float
  equipo           String
  descripcion      String?
  notas            String?
  fechaCompletada  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Todos los campos de selección son opcionales: una orden puede quedar sin
  // cliente / técnico / tipo / estado / prioridad. El bloqueo al borrar un
  // catálogo que está en uso se mantiene con onDelete: Restrict.
  clienteId   Int?
  cliente     Cliente?   @relation(fields: [clienteId], references: [id], onDelete: Restrict)

  // Técnicos asignados (varios por orden, estilo "tags"). `tecnicoIds` es la
  // fuente de verdad; `tecnicoId` se conserva como el técnico "principal"
  // (= tecnicoIds[0]) para mantener la relación/onDelete y compatibilidad.
  tecnicoIds  Int[]      @default([])
  tecnicoId   Int?
  tecnico     Tecnico?   @relation(fields: [tecnicoId], references: [id], onDelete: Restrict)

  tipoId      Int?
  tipo        Tipo?      @relation(fields: [tipoId], references: [id], onDelete: Restrict)
  estadoId    Int?
  estado      Estado?    @relation(fields: [estadoId], references: [id], onDelete: Restrict)
  prioridadId Int?
  prioridad   Prioridad? @relation(fields: [prioridadId], references: [id], onDelete: Restrict)
}
